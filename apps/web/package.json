    "tailwind-merge": "^2.6.0",
    "@complerer/reports": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
